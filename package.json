{
  "name": "xela-account-manager",
  "version": "1.0.0",
  "description": "Secure account manager with 2FA tracking and cloud backup",
  "homepage": "./",
  "private": true,
  "author": "fnetflix464-dot",
  "main": "public/electron.js",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "electron": "^31.0.0",
    "crypto-js": "^4.1.0",
    "better-sqlite3": "^8.5.0",
    "bcryptjs": "^2.4.3",
    "uuid": "^9.0.0",
    "dotenv": "^16.0.3",
    "axios": "^1.4.0",
    "googleapis": "^118.0.0",
    "dropbox": "^10.34.0"
  },
  "devDependencies": {
    "electron-builder": "^24.0.0",
    "electron-is-dev": "^2.0.0",
    "concurrently": "^8.0.0",
    "wait-on": "^7.0.0"
  },
  "scripts": {
    "react-start": "react-scripts start",
    "react-build": "react-scripts build",
    "electron-start": "electron public/electron.js",
    "start": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && npm run electron-start\"",
    "build": "npm run react-build && electron-builder",
    "dist": "npm run react-build && electron-builder --publish never"
  },
  "build": {
    "appId": "com.xela.accountmanager",
    "productName": "Xela Account Manager",
    "files": [
      "build/**/*",
      "public/electron.js",
      "public/preload.js",
      "public/database.js",
      "public/cloudBackup.js",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    }
  }
}
